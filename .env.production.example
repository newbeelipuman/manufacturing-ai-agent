APP_NAME=manufacturing-ai-agent
APP_VERSION=0.1.0
ENVIRONMENT=production
LOG_LEVEL=INFO
ENABLE_SQL_ECHO=false

# 必须修改默认数据库密码；不要提交真实 .env。
POSTGRES_DB=manufacturing_ai_agent
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=change_me_before_deploy
DATABASE_URL=postgresql+psycopg://agent_user:change_me_before_deploy@postgres:5432/manufacturing_ai_agent

REDIS_URL=redis://redis:6379/0

# 当前仍是 MVP demo，使用模拟 ERP/MES/WMS 数据，不接真实企业生产系统。
# Agent 工具只做只读查询和分析，不执行出库、调账、审批、下单等写侧业务动作。
LLM_GATEWAY_MODE=mock
LLM_PROVIDER=mock
LLM_MODEL=mock-enterprise-agent
LLM_FALLBACK_MODEL=mock-safe-fallback
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_SECONDS=20

# 必须修改默认 JWT secret；不要提交真实生产密钥。
AUTH_SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
