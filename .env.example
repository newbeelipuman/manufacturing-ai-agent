APP_NAME=manufacturing-ai-agent
APP_VERSION=0.1.0
ENVIRONMENT=local
LOG_LEVEL=INFO
ENABLE_SQL_ECHO=false

# Local development can use SQLite. Docker demo uses PostgreSQL.
DATABASE_URL=sqlite:///./local_dev.db
TEST_DATABASE_URL=sqlite:///./test.db

POSTGRES_DB=manufacturing_ai_agent
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=agent_password
REDIS_URL=redis://redis:6379/0

# Mock LLM Gateway. MVP uses local deterministic routing and does not call external models.
LLM_GATEWAY_MODE=mock
LLM_PROVIDER=mock
LLM_MODEL=mock-enterprise-agent
LLM_FALLBACK_MODEL=mock-safe-fallback
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_SECONDS=20

# Demo JWT auth. Change AUTH_SECRET_KEY outside local demos.
AUTH_SECRET_KEY=dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=120
